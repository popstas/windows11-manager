{
  "name": "windows11-manager",
  "version": "1.0.7",
  "description": "Rules based manager of windows state for Windows 11: position, desktop, pin",
  "main": "src/lib/index.js",
  "bin": "src/index.js",
  "dependencies": {
    "commander": "^14.0.3",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "node-window-manager": "file:./vendor/node-window-manager",
    "wql-process-monitor": "^3.0.2"
  },
  "scripts": {
    "version": "node scripts/sync-tauri-version.js",
    "build": "npm run version-sync && npm run build --prefix tauri-app && node -e \"import('fs').then(fs=>fs.cpSync('tauri-app/src-tauri/target/release/bundle','dist',{recursive:true}))\"",
    "start": "node src",
    "version-sync": "node scripts/sync-tauri-version.js",
    "dev": "npm run tauri dev --verbose --prefix tauri-app",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.3.0",
    "vitest": "^3.0.0"
  },
  "author": "",
  "license": "ISC",
  "type": "module"
}
